# Environment Variables
# Copy this to .env.development and fill in the values

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-change-in-production

# API — add more entries as needed (see src/configs/endpoints.ts)
NEXT_PUBLIC_API_URL=http://10.11.10.13:7040/api
# NEXT_PUBLIC_AUTH_API_URL=http://localhost:8081/api
# NEXT_PUBLIC_MEDIA_API_URL=http://localhost:8082/api
# NEXT_PUBLIC_NOTIFICATION_API_URL=http://localhost:8083/api

# SSO Login
NEXT_PUBLIC_SSO_TOKEN_API=https://kapi.iigvietnam.com/api/oauth/token
NEXT_PUBLIC_SSO_LOGIN_PAGE=https://kapiadmin.iigvietnam.com
NEXT_PUBLIC_SSO_LOGOUT_PAGE=https://kapiadmin.iigvietnam.com/logout?redirect_url=http://localhost:3000/sign-in
NEXT_PUBLIC_SSO_CHANGE_PASSWORD_PAGE=https://kapiadmin.iigvietnam.com/change-password?redirect_url=http://localhost:3000
NEXT_PUBLIC_SSO_CLIENT_ID=tfc_admin
NEXT_PUBLIC_SSO_REDIRECT_URI=http://localhost:3000/user/login
NEXT_PUBLIC_SSO_SCOPE=openid profile email
NEXT_PUBLIC_SSO_PROFILE_URL=http://10.11.10.13:7040/api/auth/profile